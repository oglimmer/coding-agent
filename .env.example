# --- Backend -----------------------------------------------------------------
ADDR=:8080
PUBLIC_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Session signing. Must be 32+ chars in production. For local dev you may set
# ALLOW_INSECURE_JWT_SECRET=true and use a short secret.
JWT_SECRET=local-dev-insecure-jwt-secret-change-me
ALLOW_INSECURE_JWT_SECRET=true
SESSION_TTL=720h

# Auth: "oidc" (production) or "password" (dev stub).
AUTH_MODE=password
DEV_PASSWORD=dev

# OIDC (used when AUTH_MODE=oidc)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid,profile,email

# Database
DATABASE_URL=postgres://coding_agent:coding_agent@localhost:5432/coding_agent?sslmode=disable

# DeepSeek harmful-content gate (and the worker's coding model).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Worker (spawned k8s Jobs) -----------------------------------------------
WORKER_IMAGE=ghcr.io/oglimmer/coding-agent-worker:latest
# Always (default) | IfNotPresent | Never. For a local cluster where you load
# the worker image instead of pulling it, use IfNotPresent.
WORKER_IMAGE_PULL_POLICY=Always
# Aider runs in architect mode: WORKER_MODEL plans the change, WORKER_EDITOR_MODEL
# turns the plan into precise edits.
WORKER_MODEL=deepseek/deepseek-v4-pro
WORKER_EDITOR_MODEL=deepseek/deepseek-chat
# K8s secret holding DEEPSEEK_API_KEY and WORKER_GITHUB_TOKEN for the worker.
WORKER_SECRET_NAME=coding-agent-secret
# Namespace for worker jobs (default: the backend's own namespace in-cluster).
#WORKER_NAMESPACE=coding-agent
#WORKER_SERVICE_ACCOUNT=
# imagePullSecret name — only needed if the ghcr package is PRIVATE. Public
# packages (the default for this project) pull anonymously; leave unset.
#WORKER_IMAGE_PULL_SECRET=
# Reviewer login the worker treats as itself while waiting for the PR review.
GITHUB_BOT_LOGIN=coding-agent-bot
REVIEW_MAX_ROUNDS=3
# Seconds a single aider round (plan+edit, or a review-fix round) may run before it
# is killed. A job runs several rounds, so keep JOB_TIMEOUT well above this.
AIDER_TIMEOUT=3600
JOB_TIMEOUT=120m
JOB_COOLDOWN=5m
MAX_CONCURRENT_JOBS=3
WATCH_INTERVAL=20s

# GitHub token used by the worker to clone/push/PR/merge. Fine-grained PAT with
# contents:write + pull_requests:write on the target repos.
WORKER_GITHUB_TOKEN=

# --- Frontend build metadata (optional) --------------------------------------
VITE_APP_VERSION=0.1.0-dev
